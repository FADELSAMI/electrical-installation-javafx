<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.isfce.pdb.view.element.VueListeElementsController">

   <children>
      <TableView fx:id="tblElements" layoutX="10" layoutY="10" prefWidth="760" prefHeight="400">
         <columns>
            <TableColumn fx:id="colCode" text="Code" prefWidth="100" />
            <TableColumn fx:id="colAppareil" text="Appareil" prefWidth="300" />
            <TableColumn fx:id="colPiece" text="Pièce" prefWidth="250" />
         </columns>
      </TableView>
   </children>
</AnchorPane>