<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.isfce.pdb.view.installation.VueChargeInstallationController"
            prefWidth="400" prefHeight="150">

   <children>
      <Label text="Installation" layoutX="30" layoutY="30" />
      <ComboBox fx:id="cbInstallations" layoutX="120" layoutY="25" prefWidth="230" />

      <Button text="Charger" layoutX="120" layoutY="85" onAction="#actionCharger" />
      <Button text="Annuler" layoutX="220" layoutY="85" onAction="#actionAnnuler" />
   </children>
</AnchorPane>